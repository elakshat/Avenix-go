<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".emergency.EmergencyContactsActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_dark"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
            app:navigationIconTint="@color/white"
            app:title="Safety Circle"
            app:titleTextColor="@color/white"
            app:titleCentered="true"
            app:titleTextAppearance="@style/TextAppearance.App.TitleLarge" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/screen_padding"
            android:paddingTop="@dimen/spacing_s"
            android:paddingBottom="120dp">

            <!-- Intro Card (Glass Style) -->
            <com.google.android.material.card.MaterialCardView
                style="@style/WayGoCard.Glass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:strokeColor="@color/accent_yellow_alpha_20">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_l"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@android:drawable/ic_menu_agenda"
                        app:tint="@color/accent_yellow"
                        android:contentDescription="Safety Circle Icon" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:layout_weight="1"
                        android:text="Trusted contacts will be notified during emergency alerts or when you share your live trip for extra security."
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        app:lineHeight="20sp"
                        tools:targetApi="p" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:text="YOUR TRUSTED CIRCLE"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.15" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvContacts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_m"
                android:nestedScrollingEnabled="false"
                tools:listitem="@android:layout/simple_list_item_2" />

            <LinearLayout
                android:id="@+id/llEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="60dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@android:drawable/ic_menu_agenda"
                    app:tint="@color/surface_variant_dark"
                    android:contentDescription="Empty Circle" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_m"
                    android:text="Your circle is empty"
                    android:textColor="@color/text_muted"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_s"
                    android:text="Add contacts to stay connected"
                    android:textColor="@color/text_muted"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddContact"
        style="@style/WayGoButton"
        android:layout_width="match_parent"
        android:layout_height="@dimen/input_height"
        android:layout_gravity="bottom"
        android:layout_margin="@dimen/spacing_l"
        android:text="Add Trusted Contact"
        app:icon="@android:drawable/ic_input_add"
        app:iconTint="@color/black"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:elevation="4dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>