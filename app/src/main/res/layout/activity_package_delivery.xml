<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".ride.PackageDeliveryActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_dark"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
            app:navigationIconTint="@color/white"
            app:title="Package Delivery"
            app:titleTextColor="@color/white"
            app:titleCentered="true"
            app:titleTextAppearance="@style/TextAppearance.App.TitleLarge" />
    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/llMainContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/screen_padding"
                    android:paddingTop="@dimen/spacing_s"
                    android:paddingBottom="40dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Send Anything,\nAnywhere"
                        android:textColor="@color/white"
                        android:textSize="36sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="-0.04"
                        app:lineHeight="40sp"
                        tools:targetApi="p" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_m"
                        android:text="Fast and secure on-demand delivery for your items with live tracking."
                        android:textColor="@color/text_secondary"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        app:lineHeight="22sp"
                        tools:targetApi="p" />

                    <!-- Visual Timeline Locations Card -->
                    <com.google.android.material.card.MaterialCardView
                        style="@style/WayGoCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xl"
                        app:cardBackgroundColor="@color/surface_dark"
                        app:strokeColor="@color/border_dark">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="4dp">

                            <LinearLayout
                                android:id="@+id/llVisuals"
                                android:layout_width="wrap_content"
                                android:layout_height="0dp"
                                android:gravity="center_horizontal"
                                android:orientation="vertical"
                                android:paddingTop="26dp"
                                android:paddingBottom="26dp"
                                android:layout_marginStart="16dp"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent">

                                <View
                                    android:layout_width="10dp"
                                    android:layout_height="10dp"
                                    android:background="@drawable/circle_shape"
                                    android:backgroundTint="@color/accent_yellow" />

                                <View
                                    android:layout_width="1.5dp"
                                    android:layout_height="0dp"
                                    android:layout_weight="1"
                                    android:layout_marginVertical="6dp"
                                    android:background="@color/border_dark" />

                                <View
                                    android:layout_width="10dp"
                                    android:layout_height="10dp"
                                    android:background="@drawable/circle_shape"
                                    android:backgroundTint="@color/white" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="16dp"
                                android:layout_marginEnd="16dp"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@id/llVisuals"
                                app:layout_constraintTop_toTopOf="parent">

                                <EditText
                                    android:id="@+id/etPickup"
                                    android:layout_width="match_parent"
                                    android:layout_height="@dimen/input_height"
                                    android:background="@android:color/transparent"
                                    android:hint="Pickup point"
                                    android:textColor="@color/white"
                                    android:textColorHint="@color/text_muted"
                                    android:textSize="16sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:singleLine="true"
                                    android:paddingEnd="16dp" />

                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="1dp"
                                    android:background="@color/divider_dark" />

                                <EditText
                                    android:id="@+id/etDropoff"
                                    android:layout_width="match_parent"
                                    android:layout_height="@dimen/input_height"
                                    android:background="@android:color/transparent"
                                    android:hint="Delivery destination"
                                    android:textColor="@color/white"
                                    android:textColorHint="@color/text_muted"
                                    android:textSize="16sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:singleLine="true"
                                    android:paddingEnd="16dp" />
                            </LinearLayout>
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xl"
                        android:text="PACKAGE DETAILS"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.1" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/WayGoInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_m"
                        android:hint="What are you sending?"
                        app:startIconDrawable="@android:drawable/ic_menu_edit"
                        app:startIconTint="@color/text_muted">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPackageContent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="18dp"
                            android:textColor="@color/white"
                            android:fontFamily="sans-serif-medium" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xl"
                        android:text="PACKAGE SIZE"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.1" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_m"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardSmall"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="@dimen/spacing_s"
                            app:cardBackgroundColor="@color/surface_variant_dark"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1.5dp"
                            app:strokeColor="@color/accent_yellow">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:padding="@dimen/spacing_m"
                                android:gravity="center"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Small"
                                    android:textColor="@color/white"
                                    android:fontFamily="sans-serif-black"
                                    android:textSize="14sp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="&lt; 2kg"
                                    android:textColor="@color/text_muted"
                                    android:textSize="11sp"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardMedium"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="@dimen/spacing_s"
                            app:cardBackgroundColor="@color/surface_dark"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="@color/border_dark">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:padding="@dimen/spacing_m"
                                android:gravity="center"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Medium"
                                    android:textColor="@color/white"
                                    android:fontFamily="sans-serif-black"
                                    android:textSize="14sp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="&lt; 7kg"
                                    android:textColor="@color/text_muted"
                                    android:textSize="11sp"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardLarge"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_s"
                            app:cardBackgroundColor="@color/surface_dark"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="@color/border_dark">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:padding="@dimen/spacing_m"
                                android:gravity="center"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Large"
                                    android:textColor="@color/white"
                                    android:fontFamily="sans-serif-black"
                                    android:textSize="14sp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="&lt; 15kg"
                                    android:textColor="@color/text_muted"
                                    android:textSize="11sp"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReviewDelivery"
                style="@style/WayGoButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:layout_marginHorizontal="@dimen/screen_padding"
                android:layout_marginBottom="@dimen/spacing_l"
                android:text="Review Order"
                app:elevation="4dp" />
        </LinearLayout>

        <!-- Searching State (Enhanced) -->
        <LinearLayout
            android:id="@+id/llSearchingState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bg_dark"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="@dimen/spacing_xl">

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/lottieSearching"
                android:layout_width="180dp"
                android:layout_height="180dp"
                app:lottie_autoPlay="true"
                app:lottie_loop="true"
                app:lottie_rawRes="@raw/search" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:text="Finding a courier..."
                android:textColor="@color/white"
                android:textSize="24sp"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:text="Wait while we assign the nearest\nverified partner for your delivery."
                android:textAlignment="center"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                app:lineHeight="22sp"
                tools:targetApi="p" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelSearch"
                style="@style/WayGoButton.Tonal"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:layout_marginTop="@dimen/spacing_xxl"
                android:text="Cancel Request" />
        </LinearLayout>
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>