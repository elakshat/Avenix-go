<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".emergency.HelplinesActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_dark"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
            app:navigationIconTint="@color/white"
            app:title="Emergency Support"
            app:titleTextColor="@color/white"
            app:titleCentered="true"
            app:titleTextAppearance="@style/TextAppearance.App.TitleLarge" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/screen_padding"
            android:paddingTop="@dimen/spacing_s"
            android:paddingBottom="@dimen/spacing_xxl">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="24/7 HELPLINES"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.15" />

            <com.google.android.material.card.MaterialCardView
                style="@style/WayGoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_m">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/spacing_s">

                    <!-- Women Helpline -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="@dimen/screen_padding"
                        android:paddingVertical="20dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:padding="14dp"
                            android:src="@android:drawable/ic_menu_call"
                            app:tint="@color/accent_yellow"
                            android:background="@color/surface_variant_dark"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.App.MediumComponent" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Women Helpline"
                                android:textColor="@color/white"
                                android:textSize="17sp"
                                android:fontFamily="sans-serif-black" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Direct support for women"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCall1091"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1091"
                            android:textColor="@color/black"
                            android:fontFamily="sans-serif-black"
                            app:backgroundTint="@color/accent_yellow"
                            app:cornerRadius="14dp" />
                    </LinearLayout>

                    <View style="@style/ProfileDivider" />

                    <!-- Universal Help -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="@dimen/screen_padding"
                        android:paddingVertical="20dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:padding="14dp"
                            android:src="@android:drawable/ic_dialog_alert"
                            app:tint="@color/accent_red"
                            android:background="@color/accent_red_alpha_20"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.App.MediumComponent" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Emergency Response"
                                android:textColor="@color/white"
                                android:textSize="17sp"
                                android:fontFamily="sans-serif-black" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="All-in-one emergency line"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCall112"
                            style="@style/WayGoButton.Outlined"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:text="112"
                            android:minHeight="0dp"
                            android:paddingHorizontal="16dp"
                            app:cornerRadius="14dp" />
                    </LinearLayout>

                    <View style="@style/ProfileDivider" />

                    <!-- Police -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="@dimen/screen_padding"
                        android:paddingVertical="20dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:padding="14dp"
                            android:src="@android:drawable/ic_lock_power_off"
                            app:tint="@color/white"
                            android:background="@color/surface_variant_dark"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.App.MediumComponent" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Police Assistance"
                                android:textColor="@color/white"
                                android:textSize="17sp"
                                android:fontFamily="sans-serif-black" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Immediate police help"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCall100"
                            style="@style/WayGoButton.Outlined"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:text="100"
                            android:minHeight="0dp"
                            android:paddingHorizontal="16dp"
                            app:cornerRadius="14dp" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:text="SAFETY PROTOCOLS"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.15" />

            <!-- Safety Tips Card (Glass Style) -->
            <com.google.android.material.card.MaterialCardView
                style="@style/WayGoCard.Glass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_m">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_l">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Before You Board"
                        android:textColor="@color/white"
                        android:fontFamily="sans-serif-black"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_m"
                        android:text="• Verify license plate and driver identity.\n• Share trip status with your safety circle.\n• Sit in the back seat and keep doors locked.\n• If something feels wrong, don't hesitate to end the trip."
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        app:lineHeight="24sp"
                        tools:targetApi="p" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>