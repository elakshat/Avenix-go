<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".profile.SafetySettingsActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_dark"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
            app:navigationIconTint="@color/white"
            app:title="Security Settings"
            app:titleTextColor="@color/white"
            app:titleCentered="true"
            app:titleTextAppearance="@style/TextAppearance.App.TitleLarge" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/screen_padding"
            android:paddingTop="@dimen/spacing_s"
            android:paddingBottom="@dimen/spacing_xxl">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RIDE VERIFICATION"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.15" />

            <!-- PIN Verification Group -->
            <com.google.android.material.card.MaterialCardView
                style="@style/WayGoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_m">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/spacing_s">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="@dimen/screen_padding"
                        android:paddingVertical="@dimen/spacing_m">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_toStartOf="@+id/switchPinVerify"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Verify with PIN"
                                android:textColor="@color/white"
                                android:textSize="17sp"
                                android:fontFamily="sans-serif-black" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Ask for a 4-digit code to start every trip."
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif-medium" />
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchPinVerify"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:checked="true" />
                    </RelativeLayout>

                    <View style="@style/ProfileDivider" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="@dimen/screen_padding"
                        android:paddingVertical="@dimen/spacing_m">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_toStartOf="@+id/switchRideCheck"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="RideCheck™ Enabled"
                                android:textColor="@color/white"
                                android:textSize="17sp"
                                android:fontFamily="sans-serif-black" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Automatic detection of unexpected stops or delays."
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif-medium" />
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchRideCheck"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:checked="true" />
                    </RelativeLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:text="AUTOMATIC SHARING"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.15" />

            <!-- Sharing Group -->
            <com.google.android.material.card.MaterialCardView
                style="@style/WayGoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_m">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/spacing_s">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="@dimen/screen_padding"
                        android:paddingVertical="@dimen/spacing_m">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_toStartOf="@+id/switchAlwaysShare"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Always Share Trip"
                                android:textColor="@color/white"
                                android:textSize="17sp"
                                android:fontFamily="sans-serif-black" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Share every trip with your safety circle."
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif-medium" />
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchAlwaysShare"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true" />
                    </RelativeLayout>

                    <View style="@style/ProfileDivider" />

                    <TextView
                        android:id="@+id/llManageContacts"
                        style="@style/ProfileOptionStyle"
                        android:text="Customize Safety Circle"
                        app:drawableStartCompat="@android:drawable/ic_menu_agenda"
                        android:drawablePadding="20dp"
                        app:drawableTint="@color/text_muted" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:text="PRIVACY &amp; MONITORING"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.15" />

            <!-- Privacy Group (Glass Style) -->
            <com.google.android.material.card.MaterialCardView
                style="@style/WayGoCard.Glass"
                android:id="@+id/llAudioRecording"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_m">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/screen_padding"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:padding="14dp"
                        android:src="@android:drawable/ic_btn_speak_now"
                        app:tint="@color/accent_yellow"
                        android:background="@color/surface_variant_dark"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.MediumComponent" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Audio Shield"
                            android:textColor="@color/white"
                            android:textSize="17sp"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Encrypted safety recordings during trips."
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_media_play"
                        app:tint="@color/text_muted"
                        android:contentDescription="Go" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>