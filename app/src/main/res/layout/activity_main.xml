<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".MainActivity">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top Overlay for status bar readability -->
    <View
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:background="@drawable/top_gradient_fade"
        android:clickable="false"
        android:focusable="false" />

    <LinearLayout
        android:id="@+id/top_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_padding"
        android:paddingTop="56dp"
        android:clickable="false"
        android:focusable="false">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_profile"
                android:layout_width="52dp"
                android:layout_height="52dp"
                app:cardCornerRadius="26dp"
                app:cardBackgroundColor="@color/surface_dark"
                app:cardElevation="6dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/glass_white_20">
                <ImageView
                    android:id="@+id/iv_profile_img"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:contentDescription="Profile Picture" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_sos_header"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="SOS"
                android:textColor="@color/white"
                app:backgroundTint="@color/accent_red"
                app:cornerRadius="26dp"
                app:icon="@android:drawable/ic_dialog_alert"
                app:iconTint="@color/white"
                android:fontFamily="sans-serif-black"
                android:paddingHorizontal="24dp"
                app:elevation="8dp" />
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:text="Where are you\ngoing today?"
            android:textColor="@color/white"
            android:textSize="42sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.04"
            android:shadowColor="@color/glass_black_80"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="8"
            app:lineHeight="46sp"
            tools:targetApi="p" />

        <!-- Segmented Tab Selection -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="@dimen/spacing_xl"
            style="@style/WayGoCard.Glass">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="5dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/ll_driver_tab"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_capsule_active"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:id="@+id/iv_driver_tab_icon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_directions"
                        app:tint="@color/black"
                        android:contentDescription="Ride Tab Icon" />
                    <TextView
                        android:id="@+id/tv_driver_tab_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Ride"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-black" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_package_tab"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:id="@+id/iv_package_tab_icon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_send"
                        app:tint="@color/white"
                        android:contentDescription="Package Tab Icon" />
                    <TextView
                        android:id="@+id/tv_package_tab_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Package"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-black" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Quick Shortcuts -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_m"
            android:orientation="horizontal">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipHome"
                style="@style/Widget.Material3.Chip.Assist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                app:chipIcon="@android:drawable/ic_menu_myplaces"
                app:chipIconTint="@color/text_muted"
                app:chipBackgroundColor="@color/surface_dark"
                app:chipStrokeColor="@color/border_dark"
                android:textColor="@color/white"
                app:chipCornerRadius="16dp"
                android:fontFamily="sans-serif-medium"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipWork"
                style="@style/Widget.Material3.Chip.Assist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Work"
                app:chipIcon="@android:drawable/ic_menu_myplaces"
                app:chipIconTint="@color/text_muted"
                app:chipBackgroundColor="@color/surface_dark"
                app:chipStrokeColor="@color/border_dark"
                android:textColor="@color/white"
                app:chipCornerRadius="16dp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <!-- Driver Info Card (Enhanced) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_driver_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:visibility="gone"
            style="@style/WayGoCard.Elevated">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_driver_profile"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.App.MediumComponent"
                    android:background="@color/surface_variant_dark"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/border_dark"
                    android:contentDescription="Driver Profile Picture" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_toEndOf="@id/iv_driver_profile"
                    android:layout_centerVertical="true"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_driver_name_info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Driver Name"
                        android:textColor="@color/white"
                        android:textSize="17sp"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:id="@+id/tv_driver_desc_info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vehicle Details"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tv_driver_rating_info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★ 5.0"
                        android:textColor="@color/accent_yellow"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-black" />
                </LinearLayout>
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <include
        android:id="@+id/bottom_sheet"
        layout="@layout/bottom_sheet_ride_options" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>