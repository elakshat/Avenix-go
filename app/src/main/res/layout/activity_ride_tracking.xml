<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".ride.RideTrackingActivity">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top Gradient for Readability -->
    <View
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:background="@drawable/top_gradient_fade"
        android:clickable="false"
        android:focusable="false" />

    <!-- Top Bar Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="56dp"
        android:paddingHorizontal="@dimen/screen_padding"
        android:clickable="false">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnBack"
                android:layout_width="52dp"
                android:layout_height="52dp"
                app:cardCornerRadius="26dp"
                style="@style/WayGoCard.Glass">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="14dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="@color/white"
                    android:contentDescription="Close Tracking" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSosTracking"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:layout_alignParentEnd="true"
                android:text="SOS"
                android:textColor="@color/white"
                app:backgroundTint="@color/accent_red"
                app:cornerRadius="26dp"
                app:icon="@android:drawable/ic_dialog_alert"
                app:iconTint="@color/white"
                android:fontFamily="sans-serif-black"
                app:elevation="8dp"
                android:paddingHorizontal="24dp" />
        </RelativeLayout>
    </LinearLayout>

    <!-- Bottom Ride Tracking Dashboard -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/rideInfoContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardBackgroundColor="@color/bg_dark"
        app:cardCornerRadius="32dp"
        app:cardElevation="24dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/border_dark"
        android:layout_marginBottom="-20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/screen_padding"
            android:paddingTop="12dp"
            android:paddingBottom="48dp">

            <View
                android:layout_width="40dp"
                android:layout_height="5dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="@dimen/spacing_l"
                android:background="@color/border_dark"
                android:backgroundTint="@color/glass_white_20" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/cardPin"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvRideStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Arriving in 4 mins"
                        android:textColor="@color/white"
                        android:textSize="26sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="-0.04" />

                    <TextView
                        android:id="@+id/tvEstimatedTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Driver is on the way"
                        android:textColor="@color/accent_yellow"
                        android:textSize="14sp"
                        android:layout_marginTop="2dp"
                        android:fontFamily="sans-serif-bold" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    app:cardBackgroundColor="@color/accent_yellow_alpha_20"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/accent_yellow">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="10dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OTP"
                            android:textSize="11sp"
                            android:textColor="@color/accent_yellow"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.1" />
                        <TextView
                            android:id="@+id/tvRidePin"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="8842"
                            android:textColor="@color/white"
                            android:textSize="20sp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.05" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </RelativeLayout>

            <!-- Location Status Row -->
            <com.google.android.material.card.MaterialCardView
                style="@style/WayGoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_l"
                app:cardBackgroundColor="@color/surface_dark">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_m">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/circle_shape"
                        android:backgroundTint="@color/accent_yellow"/>

                    <TextView
                        android:id="@+id/tvCurrentAddress"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_m"
                        android:text="123 Luxury Ave, Manhattan"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <ImageView
                        android:id="@+id/btnEditDestination"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/ic_menu_edit"
                        app:tint="@color/accent_yellow"
                        android:contentDescription="Edit Destination" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Driver Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/WayGoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@color/surface_dark"
                app:contentPadding="@dimen/spacing_m">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_driver_tracking"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.MediumComponent"
                        android:background="@color/surface_variant_dark"
                        android:scaleType="centerCrop"
                        app:strokeWidth="1.5dp"
                        app:strokeColor="@color/accent_yellow"
                        android:src="@android:drawable/ic_menu_gallery"
                        android:contentDescription="Driver Photo" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_m"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDriverName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sarah Connor"
                            android:textColor="@color/white"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:id="@+id/tvDriverInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="White Tesla Model 3 • NYC 442"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnCallDriver"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardCornerRadius="24dp"
                        app:cardBackgroundColor="@color/accent_yellow_alpha_20"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/accent_yellow">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="12dp"
                            android:src="@android:drawable/ic_menu_call"
                            app:tint="@color/accent_yellow"
                            android:contentDescription="Call Driver" />
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Main Actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShareTrip"
                    style="@style/WayGoButton.Tonal"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/input_height"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_s"
                    android:text="Share Trip"
                    app:icon="@android:drawable/ic_menu_share"
                    app:iconTint="@color/white"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/fabSafetyToolkit"
                    style="@style/WayGoButton.Tonal"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/input_height"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_s"
                    android:text="Toolkit"
                    app:icon="@android:drawable/ic_dialog_info"
                    app:iconTint="@color/white"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_m"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancelRide"
                    style="@style/WayGoButton.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/input_height"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_s"
                    android:text="Cancel"
                    android:textColor="@color/text_muted" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEndRide"
                    style="@style/WayGoButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/input_height"
                    android:layout_weight="1.2"
                    android:text="End Trip"
                    app:backgroundTint="@color/accent_red"
                    android:textColor="@color/white" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>