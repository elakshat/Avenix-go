<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/bg_dark">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Driver Simulator"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:fontFamily="sans-serif-black"
        android:layout_marginBottom="24dp" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardRequest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:backgroundTint="@color/surface_dark">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvRiderName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="New Ride Request!"
                android:textColor="@color/accent_yellow"
                android:textSize="18sp"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:id="@+id/tvPickup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:layout_marginTop="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <Button
                    android:id="@+id/btnReject"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Reject"
                    android:backgroundTint="@color/accent_red"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btnAccept"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Accept"
                    android:backgroundTint="#4CAF50" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/llActiveRide"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Accepted"
            android:textColor="@color/white"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnArriving"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mark Arriving"
            android:layout_marginTop="16dp" />

        <EditText
            android:id="@+id/etOtp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter OTP"
            android:textColorHint="@color/text_muted"
            android:textColor="@color/white"
            android:inputType="number"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/btnStartRide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start Ride" />

        <Button
            android:id="@+id/btnCompleteRide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Complete Ride"
            android:layout_marginTop="16dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvNoRequest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No pending requests..."
        android:textColor="@color/text_muted"
        android:gravity="center"
        android:layout_marginTop="48dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/btnGoOnline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Go Online"
        android:layout_marginTop="16dp" />

</LinearLayout>
