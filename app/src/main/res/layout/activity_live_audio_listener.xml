<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="@color/bg_dark">

    <ProgressBar
        android:id="@+id/audioVisualizer"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginBottom="40dp"
        android:indeterminateTint="@color/accent_yellow" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Connecting to live stream..."
        android:textColor="@color/white"
        android:textSize="22sp"
        android:fontFamily="sans-serif-black" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="You are listening to the live audio for safety monitoring."
        android:textAlignment="center"
        android:textColor="@color/text_secondary"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:lineSpacingExtra="4dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStopListening"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="60dp"
        android:backgroundTint="@color/surface_variant_dark"
        android:text="Stop Listening"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="17sp"
        android:fontFamily="sans-serif-black"
        app:cornerRadius="32dp"
        app:strokeColor="@color/accent_red"
        app:strokeWidth="1dp" />

</LinearLayout>
