<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="24dp"
    android:paddingVertical="16dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/surface_variant_dark"
        app:strokeWidth="1dp"
        app:strokeColor="#333333">

        <ImageView
            android:id="@+id/ivSuggestionIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_menu_mylocation"
            app:tint="@color/accent_yellow" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_weight="1"
        android:layout_marginStart="16dp">

        <TextView
            android:id="@+id/tvMainText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Main Address Text"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:fontFamily="sans-serif-bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvSecondaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Secondary Address Details"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvDistance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1.2 km"
        android:textColor="@color/text_muted"
        android:textSize="13sp"
        android:layout_marginStart="8dp"
        android:visibility="gone"
        android:fontFamily="sans-serif-bold" />

</LinearLayout>