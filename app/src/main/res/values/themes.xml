<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.WayGo" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand colors -->
        <item name="colorPrimary">@color/accent_yellow</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorPrimaryContainer">@color/accent_yellow_alpha</item>
        <item name="colorOnPrimaryContainer">@color/accent_yellow</item>

        <!-- Secondary brand colors -->
        <item name="colorSecondary">@color/surface_variant_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/glass_white_10</item>
        <item name="colorOnSecondaryContainer">@color/white</item>

        <!-- Background and Surface -->
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_variant_dark</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorOutline">@color/border_dark</item>

        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>

        <!-- Status bar and navigation bar -->
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>

        <!-- Shape Appearance -->
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.App.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.App.LargeComponent</item>

        <!-- Typography -->
        <item name="textAppearanceTitleLarge">@style/TextAppearance.App.TitleLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.App.HeadlineMedium</item>
    </style>

    <style name="Theme.WayGo" parent="Base.Theme.WayGo" />

    <!-- Typography Styles -->
    <style name="TextAppearance.App.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.App.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:letterSpacing">-0.04</item>
        <item name="lineHeight" tools:targetApi="p">40sp</item>
    </style>

    <!-- Fluid & Professional Shapes -->
    <style name="ShapeAppearance.App.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">24dp</item>
    </style>

    <style name="ShapeAppearance.App.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">32dp</item>
    </style>

    <style name="CircleImage" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">50%</item>
    </style>

    <!-- Custom View Styles -->
    <style name="WayGoCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/surface_dark</item>
        <item name="cardElevation">0dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.App.MediumComponent</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/border_dark</item>
    </style>

    <style name="WayGoCard.Elevated" parent="WayGoCard">
        <item name="cardElevation">6dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="WayGoCard.Glass" parent="WayGoCard">
        <item name="cardBackgroundColor">@color/glass_white_5</item>
        <item name="strokeColor">@color/glass_white_15</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="WayGoButton" parent="Widget.Material3.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">-0.01</item>
        <item name="backgroundTint">@color/accent_yellow</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:minHeight">@dimen/button_height</item>
    </style>

    <style name="WayGoButton.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="cornerRadius">20dp</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="backgroundTint">@color/surface_variant_dark</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:minHeight">@dimen/button_height</item>
    </style>

    <style name="WayGoButton.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">20dp</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="strokeColor">@color/border_dark</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:minHeight">@dimen/button_height</item>
    </style>

    <style name="WayGoInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxStrokeColor">@color/accent_yellow</item>
        <item name="hintTextColor">@color/accent_yellow</item>
        <item name="android:textColorHint">@color/text_muted</item>
        <item name="boxBackgroundColor">@color/surface_dark</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
    </style>

    <style name="ProfileOptionStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingHorizontal">20dp</item>
        <item name="android:paddingVertical">18dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="ProfileDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_marginHorizontal">20dp</item>
        <item name="android:background">@color/divider_dark</item>
    </style>

</resources>