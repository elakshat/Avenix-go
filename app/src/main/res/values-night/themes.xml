<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.WayGo" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Professional Dark Theme consistent with new aesthetic -->
        <item name="colorPrimary">@color/accent_yellow</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorPrimaryContainer">@color/accent_yellow_alpha</item>
        <item name="colorOnPrimaryContainer">@color/accent_yellow</item>

        <item name="colorSecondary">@color/surface_variant_dark</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_variant_dark</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>

        <!-- Status bar and navigation bar -->
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
    </style>
</resources>
